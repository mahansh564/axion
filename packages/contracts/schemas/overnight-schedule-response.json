{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axion.local/schemas/overnight-schedule-response.json",
  "title": "OvernightScheduleResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "goal",
    "notes",
    "hour_utc",
    "minute_utc",
    "status",
    "budget",
    "allowlist_domains",
    "runs_today_date_utc",
    "runs_today_count",
    "last_dispatched_at",
    "last_completed_at",
    "last_run_id",
    "last_run_status",
    "last_error",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "notes": { "type": ["string", "null"] },
    "hour_utc": { "type": "integer", "minimum": 0, "maximum": 23 },
    "minute_utc": { "type": "integer", "minimum": 0, "maximum": 59 },
    "status": { "type": "string", "enum": ["active", "paused"] },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_runs_per_night",
        "max_subquestions",
        "max_search_results",
        "max_fetches",
        "max_artifacts",
        "max_runtime_minutes"
      ],
      "properties": {
        "max_runs_per_night": { "type": "integer", "minimum": 1 },
        "max_subquestions": { "type": "integer", "minimum": 1 },
        "max_search_results": { "type": "integer", "minimum": 1 },
        "max_fetches": { "type": "integer", "minimum": 1 },
        "max_artifacts": { "type": "integer", "minimum": 1 },
        "max_runtime_minutes": { "type": "integer", "minimum": 1 }
      }
    },
    "allowlist_domains": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "runs_today_date_utc": { "type": ["string", "null"] },
    "runs_today_count": { "type": "integer", "minimum": 0 },
    "last_dispatched_at": { "type": ["integer", "null"] },
    "last_completed_at": { "type": ["integer", "null"] },
    "last_run_id": { "type": ["string", "null"] },
    "last_run_status": { "type": ["string", "null"] },
    "last_error": { "type": ["string", "null"] },
    "created_at": { "type": "integer" },
    "updated_at": { "type": "integer" }
  }
}
