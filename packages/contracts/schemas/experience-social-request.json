{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axion.local/schemas/experience-social-request.json",
  "title": "ExperienceSocialRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["text", "person"],
  "properties": {
    "text": { "type": "string", "minLength": 1 },
    "person": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "relationship": { "type": "string" },
    "credibility": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
