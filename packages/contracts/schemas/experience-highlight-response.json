{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axion.local/schemas/experience-highlight-response.json",
  "title": "ExperienceHighlightResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["experienceId", "documentId", "mattered_score"],
  "properties": {
    "experienceId": { "type": "string", "minLength": 1 },
    "documentId": { "type": "string", "minLength": 1 },
    "mattered_score": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
