{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axion.local/schemas/belief-uncertainty-response.json",
  "title": "BeliefUncertaintyResponse",
  "type": "object",
  "required": ["threshold", "open_questions", "low_confidence_beliefs"],
  "properties": {
    "threshold": { "type": "number", "minimum": 0, "maximum": 1 },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "question",
          "topic",
          "status",
          "linked_task_id",
          "resolution_belief_id",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "question": { "type": "string", "minLength": 1 },
          "topic": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["open", "researching", "resolved"] },
          "linked_task_id": { "type": ["string", "null"] },
          "resolution_belief_id": { "type": ["string", "null"] },
          "created_at": { "type": "integer" },
          "updated_at": { "type": "integer" }
        },
        "additionalProperties": false
      }
    },
    "low_confidence_beliefs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "statement", "topic", "confidence", "source_kind", "valid_from", "valid_to"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "topic": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "source_kind": { "type": "string", "minLength": 1 },
          "valid_from": { "type": "integer" },
          "valid_to": { "type": ["integer", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
