{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axion.local/schemas/experience-conversation-request.json",
  "title": "ExperienceConversationRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["text"],
  "properties": {
    "text": { "type": "string", "minLength": 1 },
    "channel": {
      "type": "string",
      "enum": ["conversation", "manual_log"],
      "default": "conversation"
    },
    "title": { "type": "string" }
  }
}
