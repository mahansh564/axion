{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axion.local/schemas/belief-timeline-response.json",
  "title": "BeliefTimelineResponse",
  "type": "object",
  "required": ["beliefs"],
  "properties": {
    "beliefs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "statement",
          "topic",
          "confidence",
          "source_kind",
          "source_note_id",
          "source_document_id",
          "supersedes_belief_id",
          "valid_from",
          "valid_to",
          "created_at",
          "metadata"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "topic": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "source_kind": { "type": "string", "minLength": 1 },
          "source_note_id": { "type": ["string", "null"] },
          "source_document_id": { "type": ["string", "null"] },
          "supersedes_belief_id": { "type": ["string", "null"] },
          "valid_from": { "type": "integer" },
          "valid_to": { "type": ["integer", "null"] },
          "created_at": { "type": "integer" },
          "metadata": { "type": ["object", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
