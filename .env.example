# API (apps/api)
API_PORT=3000
DATA_DIR=./data
DATABASE_URL=
# Optional: require Authorization: Bearer <key>
API_KEY=
# Web app URL used by API compatibility redirects for visualization routes
WEB_APP_URL=http://127.0.0.1:5173
# Python worker
PYTHON_WORKER_URL=http://127.0.0.1:8000
# Max multipart upload bytes (default in code if unset)
MAX_UPLOAD_BYTES=52428800
# Web app (apps/web)
VITE_API_BASE_URL=http://127.0.0.1:3000

# Python worker (apps/python-worker)
WORKER_PORT=8000
# Set to 1 in CI/tests to skip faster-whisper model load
AXION_TRANSCRIBE_STUB=0
# Transcription provider: faster-whisper|stub
AXION_TRANSCRIBE_PROVIDER=faster-whisper
# LLM extraction provider: ollama|openai|stub
AXION_LLM_PROVIDER=ollama
# Ollama for extraction (optional); if unset, worker uses deterministic stub JSON
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
# OpenAI-compatible extraction provider settings (used when AXION_LLM_PROVIDER=openai)
# OPENAI_API_KEY is required in openai mode.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
