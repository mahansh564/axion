# API (apps/api)
API_PORT=3000
DATA_DIR=./data
DATABASE_URL=
# Optional: require Authorization: Bearer <key>
API_KEY=
# Python worker
PYTHON_WORKER_URL=http://127.0.0.1:8000
# Max multipart upload bytes (default in code if unset)
MAX_UPLOAD_BYTES=52428800

# Python worker (apps/python-worker)
WORKER_PORT=8000
# Set to 1 in CI/tests to skip faster-whisper model load
AXION_TRANSCRIBE_STUB=0
# Ollama for extraction (optional); if unset, worker uses deterministic stub JSON
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
